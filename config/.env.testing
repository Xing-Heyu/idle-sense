# 测试环境配置
# 用于自动化测试

# 应用配置
APP_NAME=闲置计算加速器 (测试)
APP_VERSION=2.0.0-test
DEBUG=true

# 调度器配置
SCHEDULER_URL=http://localhost:8001
SCHEDULER_API_TIMEOUT=5
SCHEDULER_HEALTH_CHECK_TIMEOUT=2
SCHEDULER_MAX_RETRIES=1
SCHEDULER_RETRY_DELAY=0.5

# 资源配置
RESOURCE_DEFAULT_CPU_SHARE=2.0
RESOURCE_DEFAULT_MEMORY_SHARE=2048
RESOURCE_MIN_CPU_SHARE=0.5
RESOURCE_MAX_CPU_SHARE=4.0
RESOURCE_MIN_MEMORY_SHARE=256
RESOURCE_MAX_MEMORY_SHARE=4096
RESOURCE_DEFAULT_STORAGE_SHARE=2048

# Web UI 配置
WEB_PAGE_TITLE=闲置计算加速器 (测试)
WEB_PAGE_ICON=⚡
WEB_LAYOUT=wide
WEB_INITIAL_SIDEBAR_STATE=expanded
WEB_AUTO_REFRESH=false
WEB_REFRESH_INTERVAL=10
WEB_MAX_HISTORY=10
WEB_DEBUG_MODE=true

# 路径配置
PATH_USERS_DIR=./test_data/users
PATH_NODE_DATA_DIR=./test_data/node_data
PATH_LOG_DIR=./test_data/logs
PATH_TEMP_DIR=./test_data/tmp

# 分布式任务配置
DISTRIBUTED_DEFAULT_CHUNK_SIZE=5
DISTRIBUTED_DEFAULT_MAX_PARALLEL_CHUNKS=2
DISTRIBUTED_TASK_TIMEOUT=300
DISTRIBUTED_RESULT_TTL=3600

# 安全配置
SECURITY_MAX_CODE_SIZE=5000
SECURITY_MAX_INPUT_SIZE=512
SECURITY_SANDBOX_ENABLED=true
SECURITY_NETWORK_ACCESS=false
