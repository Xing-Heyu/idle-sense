# .env.production.example
# 闲置计算加速器 - 生产环境配置模板
# 复制为 .env.production 并修改相应值

# ============ 调度中心配置 ============
SCHEDULER_HOST=0.0.0.0
SCHEDULER_PORT=8000
SCHEDULER_LOG_LEVEL=WARNING
SCHEDULER_LOG_FILE=/var/log/idle-sense/scheduler.log

# 任务队列
MAX_QUEUE_SIZE=5000
RESULT_TTL=7200
CLEANUP_INTERVAL=120

# 公平调度算法
SCHEDULING_POLICY=fair_priority
FAIR_WEIGHT_WAIT_TIME=0.6
FAIR_WEIGHT_CONTRIBUTION=0.3
FAIR_WEIGHT_NEWCOMER=0.1
CONTRIBUTION_CAP=10.0
NEWCOMER_THRESHOLD=10
STARVATION_THRESHOLD=300

# Redis（生产环境推荐启用）
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379/0

# ============ 节点客户端配置 ============
NODE_SCHEDULER_URL=http://scheduler:8000
NODE_NAME=${HOSTNAME}

# 闲置检测
NODE_CHECK_INTERVAL=30
NODE_IDLE_THRESHOLD=300
NODE_CPU_THRESHOLD=30.0
NODE_MEMORY_THRESHOLD=70.0

# 安全限制
NODE_MAX_TASK_TIME=300
NODE_SECURITY_MAX_MEMORY_MB=2048
NODE_MAX_DISK_MB=500
NODE_NETWORK_ACCESS=false
NODE_AUTO_CLEANUP=true

# 资源限制
NODE_MAX_CPU_CORES=4.0
NODE_RESOURCE_MAX_MEMORY_MB=8192
NODE_RESERVE_CPU=1.0
NODE_RESERVE_MEMORY_MB=2048

# ============ 网页界面配置 ============
WEB_STREAMLIT_PORT=8501
WEB_STREAMLIT_HOST=0.0.0.0
WEB_THEME=dark
WEB_AUTO_REFRESH=true
WEB_REFRESH_INTERVAL=30

# ============ 监控配置 ============
MONITORING_ENABLED=true
METRICS_PORT=9090

# ============ 安全配置（生产环境必须修改）============
ENABLE_SSL=true
CORS_ALLOWED_ORIGINS=https://your-domain.com
SECRET_KEY=CHANGE_ME_TO_A_SECURE_RANDOM_STRING
DEBUG=false

# ============ 调试端点控制 ============
ENABLE_DEBUG_ENDPOINTS=false
