# .env.example
# 闲置计算加速器 - 环境变量配置模板
# 复制为 .env 并修改相应值

# ⚠️ 安全警告：
# - 生产环境请务必修改所有默认值
# - 敏感信息（密码、密钥）请使用强密码
# - 确保 .env 文件不被提交到版本控制

# ============ 安全配置 ============
# 生产环境必须启用 SSL
ENABLE_SSL=true
SSL_CERT_FILE=
SSL_KEY_FILE=

# CORS 配置（生产环境请限制来源）
CORS_ALLOWED_ORIGINS=http://localhost:8501

# ============ 调度中心配置 ============
SCHEDULER_HOST=127.0.0.1
SCHEDULER_PORT=8000
SCHEDULER_LOG_LEVEL=INFO
SCHEDULER_LOG_FILE=logs/scheduler.log

# 任务队列
MAX_QUEUE_SIZE=1000
RESULT_TTL=3600
CLEANUP_INTERVAL=60

# 公平调度算法
SCHEDULING_POLICY=fair_priority
FAIR_WEIGHT_WAIT_TIME=0.6
FAIR_WEIGHT_CONTRIBUTION=0.3
FAIR_WEIGHT_NEWCOMER=0.1
CONTRIBUTION_CAP=10.0
NEWCOMER_THRESHOLD=10
STARVATION_THRESHOLD=300

# Redis（可选）
# ⚠️ 生产环境请使用强密码保护 Redis
REDIS_ENABLED=false
REDIS_URL=redis://:your_password@localhost:6379/0

# ============ 节点客户端配置 ============
NODE_SCHEDULER_URL=http://localhost:8000
NODE_NAME=idle-node

# 闲置检测
NODE_CHECK_INTERVAL=30
NODE_IDLE_THRESHOLD=300
NODE_CPU_THRESHOLD=30.0
NODE_MEMORY_THRESHOLD=70.0

# 安全限制
NODE_MAX_TASK_TIME=300
NODE_SECURITY_MAX_MEMORY_MB=1024
NODE_MAX_DISK_MB=100
NODE_NETWORK_ACCESS=false
NODE_AUTO_CLEANUP=true

# 资源限制
NODE_MAX_CPU_CORES=2.0
NODE_RESOURCE_MAX_MEMORY_MB=4096
NODE_RESERVE_CPU=0.5
NODE_RESERVE_MEMORY_MB=1024

# ============ 网页界面配置 ============
WEB_STREAMLIT_PORT=8501
WEB_STREAMLIT_HOST=127.0.0.1
WEB_THEME=dark
WEB_AUTO_REFRESH=true
WEB_REFRESH_INTERVAL=10

# ============ 监控配置 ============
MONITORING_ENABLED=true
METRICS_PORT=9090

# ============ 开发配置 ============
DEBUG=false
TEST_MODE=false
